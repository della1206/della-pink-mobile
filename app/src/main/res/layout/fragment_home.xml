<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/bgHeader"
        android:layout_width="0dp"
        android:layout_height="170dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Menu Desa"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputCari"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cari Data Desa"
                app:startIconDrawable="@drawable/ic_search"
                app:helperText="Masukkan kata pencarian">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCari"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupKategori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPertanian"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pertanian"
                    android:checked="true"
                    app:chipBackgroundColor="@color/design_default_color_secondary_variant"
                    android:textColor="@android:color/white"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPengumuman"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengumuman"/>
            </com.google.android.material.chip.ChipGroup>

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:columnCount="2"
                app:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRumus"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:text="Rumus"
                    android:backgroundTint="#64BF68"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_menu"
                    app:iconGravity="textTop"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProfilPengguna"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:text="Profil"
                    android:backgroundTint="#64BF68"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_profile"
                    app:iconGravity="textTop"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPanen"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:text="Panen"
                    android:backgroundTint="#64BF68"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_home"
                    app:iconGravity="textTop"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWebView"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:text="Web Desa"
                    android:backgroundTint="#64BF68"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_web"
                    app:iconGravity="textTop"
                    app:layout_columnWeight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetting"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="8dp"
                    android:text="Tentang Aplikasi"
                    android:backgroundTint="#64BF68"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_info"
                    app:iconGravity="textStart"
                    app:layout_columnSpan="2"/>

            </androidx.gridlayout.widget.GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:text="Keluar Aplikasi"
                android:backgroundTint="#E44E4E"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>